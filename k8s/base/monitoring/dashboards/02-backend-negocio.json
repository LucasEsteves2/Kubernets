      "gridPos": { "x": 4, "y": 6, "w": 20, "h": 11 },
      "targets": [
        { "expr": "sort_desc(sum(http_requests_received_total{job=\"backend\"}) by (endpoint, method))", "legendFormat": "{{method}} {{endpoint}}", "refId": "A", "instant": true }
