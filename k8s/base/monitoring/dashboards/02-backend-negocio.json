{
  "title": "Questionario - Backend e Negocio",
  "uid": "questionario-negocio",
  "tags": ["negocio", "backend", "api", "questionario"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "graphTooltip": 1,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "API - Visao Geral",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Total de Requisicoes",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(http_requests_received_total{job=\"backend\"})", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Requisicoes/s (agora)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_received_total{job=\"backend\"}[1m]))", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "decimals": 2, "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Total de Erros (4xx + 5xx)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(http_requests_received_total{job=\"backend\", code=~\"[45]..\"})", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "background", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Taxa de Erro (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(http_requests_received_total{job=\"backend\", code=~\"[45]..\"}[5m])) / sum(rate(http_requests_received_total{job=\"backend\"}[5m])) * 100", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Latencia Mediana (p50)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m])) by (le)) * 1000", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "background", "graphMode": "none", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms", "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Memoria .NET",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(process_working_set_bytes{job=\"backend\"})", "refId": "A", "instant": true }],
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "fixedColor": "purple", "mode": "fixed" } },
        "overrides": []
      }
    },

